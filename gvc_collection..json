{
  "info": {
    "name": "Grand Valley College API - Route Aligned",
    "description": "Refactored collection matching implemented Express routes under /api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "sectorId", "value": "", "type": "string" },
    { "key": "occupationId", "value": "", "type": "string" },
    { "key": "levelId", "value": "4", "type": "string" },
    { "key": "moduleId", "value": "", "type": "string" },
    { "key": "batchId", "value": "", "type": "string" },
    { "key": "academicYearId", "value": "", "type": "string" },
    { "key": "levelModuleId", "value": "", "type": "string" },
    { "key": "instructorId", "value": "", "type": "string" },
    { "key": "staffId", "value": "", "type": "string" },
    { "key": "studentId", "value": "", "type": "string" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) {",
          "  let response = {};",
          "  try { response = pm.response.json(); } catch (e) {}",
          "",
          "  if (response.token) pm.collectionVariables.set('authToken', response.token);",
          "  if (response.user && response.user.user_id) pm.collectionVariables.set('userId', String(response.user.user_id));",
          "",
          "  const data = response.data || {};",
          "  if (data.user_id) pm.collectionVariables.set('userId', String(data.user_id));",
          "  if (data.sector_id) pm.collectionVariables.set('sectorId', String(data.sector_id));",
          "  if (data.occupation_id) pm.collectionVariables.set('occupationId', String(data.occupation_id));",
          "  if (data.level_id) pm.collectionVariables.set('levelId', String(data.level_id));",
          "  if (data.module_id) pm.collectionVariables.set('moduleId', String(data.module_id));",
          "  if (data.batch_id) pm.collectionVariables.set('batchId', String(data.batch_id));",
          "  if (data.academic_year_id) pm.collectionVariables.set('academicYearId', String(data.academic_year_id));",
          "  if (data.level_module_id) pm.collectionVariables.set('levelModuleId', String(data.level_module_id));",
          "  if (data.instructor_id) pm.collectionVariables.set('instructorId', String(data.instructor_id));",
          "  if (data.staff_id) pm.collectionVariables.set('staffId', String(data.staff_id));",
          "  if (data.student_pk) pm.collectionVariables.set('studentId', String(data.student_pk));",
          "",
          "  if (!pm.collectionVariables.get('instructorId') && response.rows && response.rows.length && response.rows[0].instructor_id) {",
          "    pm.collectionVariables.set('instructorId', String(response.rows[0].instructor_id));",
          "  }",
          "  if (!pm.collectionVariables.get('studentId') && response.rows && response.rows.length && response.rows[0].student_pk) {",
          "    pm.collectionVariables.set('studentId', String(response.rows[0].student_pk));",
          "  }",
          "}"
        ]
      }
    }
  ],
