{
  "info": {
    "name": "Grand Valley College - Student Management System",
    "description": "Complete GVC API Collection with Auto Token Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "departmentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "instructorId",
      "value": "",
      "type": "string"
    },
    {
      "key": "moduleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sectorId",
      "value": "",
      "type": "string"
    },
    {
      "key": "occupationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ucId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Pre-request script for authentication",
          "if (pm.collectionVariables.get('authToken')) {",
          "    pm.request.headers.upsert({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.collectionVariables.get('authToken')",
          "    });",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Extract and store data from responses",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    const response = pm.response.json();",
          "    ",
          "    // Store auth token from login",
          "    if (response.token) {",
          "        pm.collectionVariables.set('authToken', response.token);",
          "        console.log('✅ Token stored successfully');",
          "    }",
          "    ",
          "    // Store user data",
          "    if (response.user && response.user.id) {",
          "        pm.collectionVariables.set('userId', response.user.id);",
          "    }",
          "    ",
          "    // Store department ID",
          "    if (response.data && response.data.id && pm.request.url.toString().includes('departments')) {",
          "        pm.collectionVariables.set('departmentId', response.data.id);",
          "        console.log('📚 Department ID stored:', response.data.id);",
          "    }",
          "    ",
          "    // Store student ID",
          "    if (response.data && response.data.id && pm.request.url.toString().includes('students')) {",
          "        pm.collectionVariables.set('studentId', response.data.id);",
          "        console.log('👨‍🎓 Student ID stored:', response.data.id);",
          "    }",
          "    ",
          "    // Store instructor ID",
          "    if (response.data && response.data.id && pm.request.url.toString().includes('instructors')) {",
          "        pm.collectionVariables.set('instructorId', response.data.id);",
          "        console.log('👨‍🏫 Instructor ID stored:', response.data.id);",
          "    }",
          "    ",
          "    // Store curriculum data",
          "    if (response.data && response.data.id) {",
          "        if (pm.request.url.toString().includes('modules')) {",
          "            pm.collectionVariables.set('moduleId', response.data.id);",
          "            console.log('📖 Module ID stored:', response.data.id);",
          "        }",
          "        if (pm.request.url.toString().includes('sectors')) {",
          "            pm.collectionVariables.set('sectorId', response.data.id);",
          "            console.log('🏢 Sector ID stored:', response.data.id);",
          "        }",
          "        if (pm.request.url.toString().includes('occupations')) {",
          "            pm.collectionVariables.set('occupationId', response.data.id);",
          "            console.log('💼 Occupation ID stored:', response.data.id);",
          "        }",
          "        if (pm.request.url.toString().includes('ucs')) {",
          "            pm.collectionVariables.set('ucId', response.data.id);",
          "            console.log('📋 Unit of Competence ID stored:', response.data.id);",
          "        }",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
