{
	"info": {
		"name": "GVC Student Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
     "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
    
  ],
	"item": [
		{
			"name": "Auth Module",
			"item": [
				{
					"name": "1. Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"token\", jsonData.token);",
									"    console.log(\"✅ Token captured and saved to environment!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@gvc.edu\",\n    \"password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login" }
					}
				},
				{
					"name": "2. Get Users (PFSS)",
					"request": {
						"method": "GET",
						"header": [
							{ 
                            "key": "Authorization", 
                            "value": "Bearer {{token}}", 
                            "type": "text" }
						],
						"url": {
							"raw": "{{baseUrl}}/auth?page=1&limit=10&search=admin",
							"host": ["{{baseUrl}}"],
							"path": ["auth"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "search", "value": "admin" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Academics Module",
			"item": [
				{
					"name": "1. Create Department",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"department_code\": \"HNS\",\n    \"department_name\": \"Hardware and Networking System\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/academics/departments" }
					}
				},
				{
					"name": "2. List Departments",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": { "raw": "{{baseUrl}}/academics/departments" }
					}
				}
			]
		},
		{
			"name": "Student Module",
			"item": [
				{
					"name": "1. Register Student (Atomic ID Gen)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"full_name\": \"Muzafar Jemal Abakoyas\",\n    \"gender\": \"M\",\n    \"educational_stream\": \"Natural\",\n    \"department_id\": 1,\n    \"program_id\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/students/register" }
					}
				},
				{
					"name": "2. Get Students (Search/Filter)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{baseUrl}}/students?search=Muzafar&status=Active",
							"host": ["{{baseUrl}}"],
							"path": ["students"],
							"query": [
								{ "key": "search", "value": "Muzafar" },
								{ "key": "status", "value": "Active" }
							]
						}
					}
				}
			]
		}
	]
}