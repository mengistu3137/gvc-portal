              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gvc.edu\",\n  \"password\": \"admin123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "response": []
        },
        {
          "name": "Get Users",
          "request": {
